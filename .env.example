# ─────────────────────────────────────────────────────────────────────────────
# DoorX Environment Variables
# Copy this file to .env.local for development
# Set these in Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Vercel Postgres or Neon) ────────────────────────────────────────
# Get from: Vercel Dashboard → Storage → Postgres → Connect
DATABASE_URL="postgresql://user:password@host:5432/doorx?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:password@host:5432/doorx"

# ── Security ──────────────────────────────────────────────────────────────────
# Random 64-char hex string — used for internal API auth
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET="your-64-char-hex-secret-here"

# Salt for IP hashing (never store raw IPs)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_HASH_SALT="your-ip-hash-salt-here"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your frontend domains)
ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# ── Vercel ────────────────────────────────────────────────────────────────────
# These are set automatically by Vercel:
# VERCEL_URL, VERCEL_ENV, VERCEL_REGION
